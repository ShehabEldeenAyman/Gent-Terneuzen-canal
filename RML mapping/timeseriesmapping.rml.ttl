@base <http://example.com/base/> .
@prefix rr:  <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:  <http://semweb.mmlab.be/ns/ql#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:   <http://example.com/attributes/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<#SensorMapping> a rr:TriplesMap;
  rml:logicalSource [
    rml:source "../data fetch/data/timeseries.csv";
    rml:referenceFormulation ql:CSV
  ];

  # Core Subject Map
  rr:subjectMap [
    rr:template "http://example.com/observations/{ts_id}/{Timestamp}" ;
    rr:class sosa:Observation
  ];

  # Sensor / ts_id (Transformed to URI instead of string)
  rr:predicateObjectMap [
    rr:predicate sosa:madeBySensor ;
    rr:objectMap [
        rr:template "http://example.com/waterinfo/{ts_id}" ;
        rr:termType rr:IRI
    ]
  ] ;

  # Timestamp -> sosa:resultTime
  rr:predicateObjectMap [
    rr:predicate sosa:resultTime ;
    rr:objectMap [
      rml:reference "Timestamp" ;
      rr:datatype xsd:dateTime
    ]
  ] ;

  # Value -> sosa:hasSimpleResult
  rr:predicateObjectMap [
    rr:predicate sosa:hasSimpleResult ;
    rr:objectMap [
      rml:reference "Value" ;
      rr:datatype xsd:double
    ]
  ] ;

  # Interpolation Type (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:interpolationType ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Interpolation Type}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Quality Code (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:qualityCode ;
    rr:objectMap [
      rml:reference "Quality Code" ;
      rr:datatype xsd:integer
    ]
  ] ;

  # Quality Code Name (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:qualityCodeName ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Quality Code Name}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Quality Code Description (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:qualityCodeDescription ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Quality Code Description}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Quality Code Color (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:qualityCodeColor ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Quality Code Color}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Aggregation Accuracy % (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:aggregationAccuracy ;
    rr:objectMap [
      rml:reference "Aggregation Accuracy %" ;
      rr:datatype xsd:double
    ]
  ] ;

  # Absolute Value (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:absoluteValue ;
    rr:objectMap [
      rml:reference "Absolute Value" ;
      rr:datatype xsd:double
    ]
  ] ;

  # AV Interpolation Type (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:avInterpolationType ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{AV Interpolation Type}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # AV Quality Code (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:avQualityCode ;
    rr:objectMap [
      rml:reference "AV Quality Code" ;
      rr:datatype xsd:integer
    ]
  ] ;

  # AV Quality Code Name (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:avQualityCodeName ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{AV Quality Code Name}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # AV Quality Code Description (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:avQualityCodeDescription ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{AV Quality Code Description}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Runoff Value (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:runoffValue ;
    rr:objectMap [
      rml:reference "Runoff Value" ;
      rr:datatype xsd:double
    ]
  ] ;

  # RV Interpolation Type (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:rvInterpolationType ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{RV Interpolation Type}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # RV Quality Code (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:rvQualityCode ;
    rr:objectMap [
      rml:reference "RV Quality Code" ;
      rr:datatype xsd:integer
    ]
  ] ;

  # RV Quality Code Name (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:rvQualityCodeName ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{RV Quality Code Name}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # RV Quality Code Description (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:rvQualityCodeDescription ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{RV Quality Code Description}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Stagesource Value (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:stagesourceValue ;
    rr:objectMap [
      rml:reference "Stagesource Value" ;
      rr:datatype xsd:double
    ]
  ] ;

  # ReturnPeriod (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:returnPeriod ;
    rr:objectMap [
      rml:reference "ReturnPeriod" ;
      rr:datatype xsd:double
    ]
  ] ;

  # Occurrance Timestamp
  rr:predicateObjectMap [
    rr:predicate ex:occurranceTimestamp ;
    rr:objectMap [
      rml:reference "Occurrance Timestamp" ;
      rr:datatype xsd:dateTime
    ]
  ] ;

  # Occurrance Count (Numeric)
  rr:predicateObjectMap [
    rr:predicate ex:occurranceCount ;
    rr:objectMap [
      rml:reference "Occurrance Count" ;
      rr:datatype xsd:integer
    ]
  ] ;

  # Timeseries Comment (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:timeseriesComment ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Timeseries Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Agent Comment (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:agentComment ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Agent Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Station Comment (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:stationComment ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Station Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Parameter Comment (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:parameterComment ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Parameter Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Data Comment (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:dataComment ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Data Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Release State (String -> URI)
  rr:predicateObjectMap [
    rr:predicate ex:releaseState ;
    rr:objectMap [
      rr:template "http://example.com/waterinfo/{Release State}" ;
      rr:termType rr:IRI
    ]
  ] .