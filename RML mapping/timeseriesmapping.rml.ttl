@base <http://example.com/base/> .
@prefix rr:    <http://www.w3.org/ns/r2rml#> .
@prefix rml:   <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:    <http://semweb.mmlab.be/ns/ql#> .
@prefix sosa:  <http://www.w3.org/ns/sosa/> .
@prefix ssn:   <http://www.w3.org/ns/ssn/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex:    <http://example.com/attributes/> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix obs:   <http://example.com/observations/> .
@prefix waterinfo: <http://example.com/waterinfo/> .

<#SensorMapping> a rr:TriplesMap;
  rml:logicalSource [
    rml:source "../data/timeseries.csv";
    rml:referenceFormulation ql:CSV
  ];

  # Core Subject Map
  rr:subjectMap [
    rr:template "obs:{ts_id}/{Timestamp}" ;
    rr:class sosa:Observation
  ];

  # Sensor / ts_id
  rr:predicateObjectMap [
    rr:predicate sosa:madeBySensor ;
    rr:objectMap [
        rr:template "waterinfo:{ts_id}" ;
        rr:termType rr:IRI
    ]
  ] ;

  # Timestamp -> sosa:resultTime
  rr:predicateObjectMap [
    rr:predicate sosa:resultTime ;
    rr:objectMap [
      rml:reference "Timestamp" ;
      rr:datatype xsd:dateTime
    ]
  ] ;

  # Value -> sosa:hasSimpleResult
  rr:predicateObjectMap [
    rr:predicate sosa:hasSimpleResult ;
    rr:objectMap [
      rml:reference "Value" ;
      rr:datatype xsd:double
    ]
  ] ;

# Interpolation Type -> String
  rr:predicateObjectMap [
    rr:predicate ex:interpolationType ;
    rr:objectMap [
      rml:reference "Interpolation Type" ;
      rr:datatype xsd:string
    ]
  ];

  # Quality Code
  rr:predicateObjectMap [
    rr:predicate ex:qualityCode ;
    rr:objectMap [
      rml:reference "Quality Code" ;
      rr:datatype xsd:integer
    ]
  ] ;

# Quality Code Name -> Now a String
  rr:predicateObjectMap [
    rr:predicate ex:qualityCodeName ;
    rr:objectMap [
      rml:reference "Quality Code Name" ;
      rr:datatype xsd:string
    ]
  ] ;

# Quality Code Description -> Now a String
  rr:predicateObjectMap [
    rr:predicate ex:qualityCodeDescription ;
    rr:objectMap [
      rml:reference "Quality Code Description" ;
      rr:datatype xsd:string
    ]
  ] ;


# Quality Code Color -> Now a String
  rr:predicateObjectMap [
    rr:predicate ex:qualityCodeColor ;
    rr:objectMap [
      rml:reference "Quality Code Color" ;
      rr:datatype xsd:string
    ]
  ] ;

  # Aggregation Accuracy %
  rr:predicateObjectMap [
    rr:predicate ex:aggregationAccuracy ;
    rr:objectMap [
      rml:reference "Aggregation Accuracy %" ;
      rr:datatype xsd:double
    ]
  ] ;

  # Absolute Value
  rr:predicateObjectMap [
    rr:predicate ex:absoluteValue ;
    rr:objectMap [
      rml:reference "Absolute Value" ;
      rr:datatype xsd:double
    ]
  ] ;

# AV Interpolation Type -> String
  rr:predicateObjectMap [
    rr:predicate ex:avInterpolationType ;
    rr:objectMap [
      rml:reference "AV Interpolation Type" ;
      rr:datatype xsd:string
    ]
  ] ;

  # AV Quality Code
  rr:predicateObjectMap [
    rr:predicate ex:avQualityCode ;
    rr:objectMap [
      rml:reference "AV Quality Code" ;
      rr:datatype xsd:integer
    ]
  ] ;

  # AV Quality Code Name
  rr:predicateObjectMap [
    rr:predicate ex:avQualityCodeName ;
    rr:objectMap [
      rr:template "waterinfo:{AV Quality Code Name}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # AV Quality Code Description
  rr:predicateObjectMap [
    rr:predicate ex:avQualityCodeDescription ;
    rr:objectMap [
      rr:template "waterinfo:{AV Quality Code Description}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Runoff Value
  rr:predicateObjectMap [
    rr:predicate ex:runoffValue ;
    rr:objectMap [
      rml:reference "Runoff Value" ;
      rr:datatype xsd:double
    ]
  ] ;

# RV Interpolation Type -> String
  rr:predicateObjectMap [
    rr:predicate ex:rvInterpolationType ;
    rr:objectMap [
      rml:reference "RV Interpolation Type" ;
      rr:datatype xsd:string
    ]
  ] ;

  # RV Quality Code
  rr:predicateObjectMap [
    rr:predicate ex:rvQualityCode ;
    rr:objectMap [
      rml:reference "RV Quality Code" ;
      rr:datatype xsd:integer
    ]
  ] ;

  # RV Quality Code Name
  rr:predicateObjectMap [
    rr:predicate ex:rvQualityCodeName ;
    rr:objectMap [
      rr:template "waterinfo:{RV Quality Code Name}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # RV Quality Code Description
  rr:predicateObjectMap [
    rr:predicate ex:rvQualityCodeDescription ;
    rr:objectMap [
      rr:template "waterinfo:{RV Quality Code Description}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Stagesource Value
  rr:predicateObjectMap [
    rr:predicate ex:stagesourceValue ;
    rr:objectMap [
      rml:reference "Stagesource Value" ;
      rr:datatype xsd:double
    ]
  ] ;

  # ReturnPeriod
  rr:predicateObjectMap [
    rr:predicate ex:returnPeriod ;
    rr:objectMap [
      rml:reference "ReturnPeriod" ;
      rr:datatype xsd:double
    ]
  ] ;

  # Occurrance Timestamp
  rr:predicateObjectMap [
    rr:predicate ex:occurranceTimestamp ;
    rr:objectMap [
      rml:reference "Occurrance Timestamp" ;
      rr:datatype xsd:dateTime
    ]
  ] ;

  # Occurrance Count
  rr:predicateObjectMap [
    rr:predicate ex:occurranceCount ;
    rr:objectMap [
      rml:reference "Occurrance Count" ;
      rr:datatype xsd:integer
    ]
  ] ;

  # Timeseries Comment
  rr:predicateObjectMap [
    rr:predicate ex:timeseriesComment ;
    rr:objectMap [
      rr:template "waterinfo:{Timeseries Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Agent Comment
  rr:predicateObjectMap [
    rr:predicate ex:agentComment ;
    rr:objectMap [
      rr:template "waterinfo:{Agent Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Station Comment
  rr:predicateObjectMap [
    rr:predicate ex:stationComment ;
    rr:objectMap [
      rr:template "waterinfo:{Station Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Parameter Comment
  rr:predicateObjectMap [
    rr:predicate ex:parameterComment ;
    rr:objectMap [
      rr:template "waterinfo:{Parameter Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Data Comment
  rr:predicateObjectMap [
    rr:predicate ex:dataComment ;
    rr:objectMap [
      rr:template "waterinfo:{Data Comment}" ;
      rr:termType rr:IRI
    ]
  ] ;

  # Release State
  rr:predicateObjectMap [
    rr:predicate ex:releaseState ;
    rr:objectMap [
      rr:template "waterinfo:{Release State}" ;
      rr:termType rr:IRI
    ]
  ] .